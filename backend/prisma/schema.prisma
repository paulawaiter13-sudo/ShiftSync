generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IncidentStatus {
  Open
  Investigating
  Monitoring
  Resolved
  Closed
}

enum IncidentCategory {
  Infrastructure
  Network
  Application
  Security
  Database
  ThirdParty
  Other
}

enum IncidentEnvironment {
  Production
  Staging
  Internal
  Other
}

model Alert {
  id                     String              @id @default(cuid())
  title                  String
  description            String
  source                 String
  service                String
  /// Allowed values: Low, Medium, High, Critical
  severity               String
  /// Allowed values: New, Acknowledged, Investigating, Closed
  status                 String              @default("New")
  triggeredAt            DateTime
  acknowledgedBy         String?
  investigationStartedAt DateTime?
  lastUpdatedBy          String?
  relatedIncidentId      String?             @unique
  relatedIncident        Incident?           @relation("AlertRelatedIncident", fields: [relatedIncidentId], references: [id], onDelete: SetNull)
  declaredIncident       Incident?           @relation("IncidentSourceAlert")
  shiftDate              DateTime
  tags                   String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  investigationNotes     InvestigationNote[]
  handoverLinks          HandoverAlert[]

  @@index([status])
  @@index([severity])
  @@index([source])
  @@index([service])
  @@index([triggeredAt])
}

model Incident {
  id              String               @id @default(cuid())
  title           String
  description     String
  category        IncidentCategory
  severity        String
  status          IncidentStatus       @default(Open)
  affectedService String
  environment     IncidentEnvironment
  reportedBy      String
  assignedTo      String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  resolvedAt      DateTime?
  sourceAlertId   String?              @unique
  sourceAlert     Alert?               @relation("IncidentSourceAlert", fields: [sourceAlertId], references: [id], onDelete: SetNull)
  linkedFromAlert Alert?               @relation("AlertRelatedIncident")
  handoverLinks   HandoverIncident[]

  @@index([status])
  @@index([severity])
  @@index([category])
  @@index([affectedService])
  @@index([createdAt])
}

model InvestigationNote {
  id        String   @id @default(cuid())
  alertId   String
  message   String
  /// Allowed values: Note, Action, Escalation, Update
  type      String
  createdBy String
  createdAt DateTime @default(now())
  alert     Alert    @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@index([alertId, createdAt])
}

enum ShiftType {
  Morning
  Evening
  Night
}

enum HandoverStatus {
  Draft
  Ready
  Completed
}

enum FollowUpPriority {
  Low
  Medium
  High
  Critical
}

enum FollowUpStatus {
  Open
  InProgress
  Done
}

model ShiftHandover {
  id             String           @id @default(cuid())
  shiftDate      DateTime         @db.Date
  shiftType      ShiftType
  createdBy      String
  status         HandoverStatus   @default(Draft)
  summary        String           @default("")
  nextShiftNotes String           @default("")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  completedAt    DateTime?

  selectedAlerts    HandoverAlert[]
  selectedIncidents HandoverIncident[]
  followUpItems     HandoverFollowUpItem[]

  @@index([status])
  @@index([shiftType])
  @@index([shiftDate])
}

model HandoverAlert {
  handoverId String
  alertId    String
  handover   ShiftHandover @relation(fields: [handoverId], references: [id], onDelete: Cascade)
  alert      Alert         @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@id([handoverId, alertId])
  @@index([alertId])
}

model HandoverIncident {
  handoverId String
  incidentId String
  handover   ShiftHandover @relation(fields: [handoverId], references: [id], onDelete: Cascade)
  incident   Incident      @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@id([handoverId, incidentId])
  @@index([incidentId])
}

model HandoverFollowUpItem {
  id          String            @id @default(cuid())
  handoverId  String
  title       String
  description String
  owner       String?
  priority    FollowUpPriority
  status      FollowUpStatus    @default(Open)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  handover    ShiftHandover     @relation(fields: [handoverId], references: [id], onDelete: Cascade)

  @@index([handoverId])
  @@index([status])
}
